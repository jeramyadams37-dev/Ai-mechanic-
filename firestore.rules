rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "jeramyadams37@gmail.com";
    }

    match /vehicles/{vehicleId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.ownerId;
      allow update: if (isDocOwner() || isAdmin()) && request.auth.uid == request.resource.data.ownerId;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /maintenance/{logId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.ownerId;
      allow update: if (isDocOwner() || isAdmin()) && request.auth.uid == request.resource.data.ownerId;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.ownerId;
      allow update: if (isDocOwner() || isAdmin()) && request.auth.uid == request.resource.data.ownerId;
      allow delete: if isDocOwner() || isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
